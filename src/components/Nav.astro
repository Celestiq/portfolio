---
import site from '../data/site.json';

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function isCurrent(href: string) {
  if (href === base + '/') return currentPath === base + '/' || currentPath === base;
  return currentPath.startsWith(href);
}
---

<nav class="site-nav" aria-label="Site navigation">
  <div class="nav-inner">
    <a href={`${base}/`} class="nav-brand">{site.title}</a>
    <ul class="nav-links">
      <li>
        <a href={`${base}/`} aria-current={isCurrent(base + '/') ? 'page' : undefined}>
          About
        </a>
      </li>
      <li>
        <a href={`${base}/writings`} aria-current={isCurrent(base + '/writings') ? 'page' : undefined}>
          Writing
        </a>
      </li>
      <li>
        <a href={`${base}/projects`} aria-current={isCurrent(base + '/projects') ? 'page' : undefined}>
          Projects
        </a>
      </li>
    </ul>
  </div>
</nav>
